{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],

    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@pages/*": ["framework/pages/*"],
      "@flows/*": ["framework/flows/*"],
      "@fixtures/*": ["framework/fixtures/*"],
      "@data/*": ["framework/data/*"]
    }
  },
  "include": ["tests", "framework", "playwright.config.ts"]
}
